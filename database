import sqlite3

conn = sqlite3.connect('database.db')

cur = conn.cursor()

cur.execute("CREATE TABLE users(user_id primary key,username text not null,password text not null)")

cur.execute("CREATE TABLE players(player_id primary key, player_name text not null)")

cur.execute("CREATE TABLE leagues(leagues_id primary key, league_name text not null)")


cur.commit()






conn.close()


